# Copy this file to .env and fill in your Azure credentials.
# Never commit .env to git.

# Azure AI Vision resource endpoint (found in Azure portal → your resource → Keys and Endpoint)
VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com

# Azure AI Vision API key (Key 1 or Key 2)
VISION_KEY=your_azure_vision_key_here

# Where to save uploaded images for debugging
UPLOAD_DIR=uploads

# Seconds before Azure API calls time out
REQUEST_TIMEOUT=15

# CV backend: "azure" (default) or "local" (Ollama + EasyOCR, no internet needed)
VISION_BACKEND=azure

# Local backend settings (only used when VISION_BACKEND=local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=moondream
